{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentteam.local/schemas/native_runtime/agent_pool.schema.json",
  "title": "AgentTeam Native Runtime Agent Pool",
  "type": "object",
  "additionalProperties": false,
  "required": ["pool_id", "scheduler_agent_id", "updated_at", "agents"],
  "properties": {
    "pool_id": {
      "type": "string",
      "minLength": 1
    },
    "scheduler_agent_id": {
      "type": "string",
      "pattern": "^agent-[a-z0-9][a-z0-9_-]*$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "role_runtime_profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["adapter"],
        "properties": {
          "adapter": {
            "type": "string",
            "enum": ["fake", "shell", "codex"]
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "sandbox": {
            "type": "string",
            "minLength": 1
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1
          },
          "command": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "fallback_worktree_path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "$ref": "agent_state.schema.json"
      },
      "minItems": 1
    }
  }
}
