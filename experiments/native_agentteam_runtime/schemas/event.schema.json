{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentteam.local/schemas/native_runtime/event.schema.json",
  "title": "AgentTeam Native Runtime Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "sequence",
    "time",
    "event_type",
    "actor",
    "idempotency_key",
    "correlation_id",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^EVT-[0-9]+$"
    },
    "run_id": {
      "type": ["string", "null"]
    },
    "step_id": {
      "type": ["string", "null"]
    },
    "source_event_id": {
      "type": ["string", "null"]
    },
    "source_event_sequence": {
      "type": ["integer", "null"]
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "scheduler_started",
        "message_dispatched",
        "agent_woke",
        "agent_result",
        "agent_lease_expired",
        "result_validated",
        "result_rejected",
        "backlog_updated",
        "checkpoint",
        "task_selected",
        "task_reassigned",
        "lease_acquired",
        "worktree_created",
        "worktree_removed",
        "runtime_session_started",
        "runtime_session_observed",
        "runtime_session_stopped",
        "runtime_output_received",
        "validation_accepted",
        "validation_rejected",
        "integration_queued",
        "patch_integrated",
        "integration_verified",
        "integration_commit_evaluated",
        "artifact_update_proposed",
        "artifact_update_integrated",
        "attempt_timed_out",
        "attempt_cancelled",
        "recovery_routed"
      ]
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "target_agent_id": {
      "type": ["string", "null"]
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    }
  }
}
