  "checks": [
    {
      "id": "ROLE_RUNTIME_BOUNDARY",
      "name": "logical roles and runtime sessions are not conflated",
      "check_type": "required_reference",
      "target_artifacts": [
        "specs/runtime_semantics.md"
      ],
      "parameters": {
        "required_terms": [
          "RoleAgent",
          "RuntimeSession",
          "Worktree"
        ]
      },
      "blocking": true,
      "owner": "validator",
      "rationale": "The native runtime must not recreate Codex subagent semantics as the authority model."
    },
    {
      "id": "WORKTREE_ATTEMPT_BOUNDARY",
      "name": "worktrees are bound to writable attempts",
      "check_type": "required_reference",
      "target_artifacts": [
        "specs/runtime_semantics.md"
      ],
      "parameters": {
        "required_phrase": "one writable attempt, one worktree"
      },
      "blocking": true,
      "owner": "validator",
      "rationale": "The architecture must not allocate worktrees to long-lived role identity by default."
    },
    {
      "id": "AUTHORITY_GATE_PRESENT",
      "name": "authority updates require validation and integration",
      "check_type": "required_reference",
      "target_artifacts": [
        "specs/runtime_semantics.md",
        "acceptance_contract.json"
      ],
      "parameters": {
        "required_terms": [
          "Validator",
          "Integrator",
          "authority"
        ]
      },
      "blocking": true,
      "owner": "validator",
      "rationale": "Raw model output cannot mutate semantic or implementation authority."
    },
    {
      "id": "A2A_POSTPONED",
      "name": "A2A is not part of M0 or M1",
      "check_type": "required_reference",
      "target_artifacts": [
        "constraints.json",
        "specs/runtime_semantics.md"
      ],
      "parameters": {
        "required_terms": [
          "A2A",
          "postponed"
        ]
      },
      "blocking": true,
      "owner": "validator",
      "rationale": "The user explicitly chose not to use A2A for the initial design."
    }
  ]
}
