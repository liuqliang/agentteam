#!/usr/bin/env python3
import json
import os
import sys
from pathlib import Path


def main():
    runtime_root = _active_release_runtime_root(sys.argv[1:]) or _development_runtime_root()
    sys.path.insert(0, str(runtime_root))
    from agentteam_runtime.agentteam import main as agentteam_main

    return agentteam_main()


def _active_release_runtime_root(argv):
    project_root = _project_root_from_argv(argv)
    profile_path = project_root / ".agentteam" / "profile.json"
    if not profile_path.exists():
        return None
    try:
        profile = json.loads(profile_path.read_text(encoding="utf-8"))
        work_root = Path(profile["work_root"])
        active = json.loads((work_root / "releases" / "active.json").read_text(encoding="utf-8"))
    except (OSError, KeyError, json.JSONDecodeError):
        return None
    release_root = active.get("release_root")
    if not release_root:
        return None
    runtime_root = Path(release_root) / "experiments" / "native_agentteam_runtime" / "m0_runtime"
    if (runtime_root / "agentteam_runtime" / "agentteam.py").exists():
        return runtime_root
    return None


def _project_root_from_argv(argv):
    for index, arg in enumerate(argv):
        if arg == "--project-root" and index + 1 < len(argv):
            return Path(argv[index + 1]).resolve()
        if arg.startswith("--project-root="):
            return Path(arg.split("=", 1)[1]).resolve()
    return Path.cwd().resolve()


def _development_runtime_root():
    configured = _configured_development_repo_root()
    if configured:
        return configured / "experiments" / "native_agentteam_runtime" / "m0_runtime"
    repo_root = Path(__file__).resolve().parent
    return repo_root / "experiments" / "native_agentteam_runtime" / "m0_runtime"


def _configured_development_repo_root():
    env_root = os.environ.get("AGENTTEAM_DEV_ROOT")
    if env_root:
        return Path(env_root).resolve()
    config_path = Path.home() / ".local" / "share" / "agentteam" / "launcher.json"
    if not config_path.exists():
        return None
    try:
        config = json.loads(config_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    repo_root = config.get("development_repo_root")
    return Path(repo_root).resolve() if repo_root else None


if __name__ == "__main__":
    raise SystemExit(main())
